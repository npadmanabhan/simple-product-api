PORT=3000
MONGO_URI=mongodb://localhost:27017/product-api
NODE_ENV=development

# Comma-separated list of allowed CORS origins.
# Not needed for local dev — the Vite proxy forwards requests server-side so no CORS headers are required.
# Required in production: set to the Cloud Run UI URL (e.g. https://your-ui.run.app).
ALLOWED_ORIGINS=

# Log level: error | warn | info | debug (default: info)
LOG_LEVEL=info
